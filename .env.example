# ═══════════════════════════════════════════════════════════
# TokenSaver Configuration — copy to .env and fill in values
# ═══════════════════════════════════════════════════════════

# ─── Manager ────────────────────────────────────────────────
TOKENSAVER_MANAGER_PORT=3001
TOKENSAVER_DB_PATH=./data/savings.db
TOKENSAVER_POLL_INTERVAL=60
TOKENSAVER_LICENSE_KEY=dev-mode              # Set a strong random value in production!
TOKENSAVER_STANDALONE=false                  # Enable standalone mode (Enterprise tier)

# ─── Headroom ──────────────────────────────────────────────
HEADROOM_URL=http://127.0.0.1:8787
HEADROOM_REQUIRE_RUST_CORE=false
HEADROOM_TELEMETRY=off

# ─── Caching Proxy ─────────────────────────────────────────
TOKENSAVER_PROXY_PORT=8788
TOKENSAVER_PROXY_UPSTREAM=https://api.openai.com
TOKENSAVER_CACHE_TTL=24                      # Cache TTL (hours)
TOKENSAVER_SEMANTIC_THRESHOLD=0.92           # Cosine similarity threshold
TOKENSAVER_RATE_LIMIT_REQUESTS=0             # 0 = unlimited
TOKENSAVER_RATE_LIMIT_WINDOW=60              # Window in seconds

# ─── Upstream API Keys ─────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Slack Alerts ──────────────────────────────────────────
SLACK_WEBHOOK_URL=                           # Default Slack webhook URL

# ─── Email Alerts (SMTP) ───────────────────────────────────
TOKENSAVER_SMTP_HOST=                        # e.g. smtp.gmail.com
TOKENSAVER_SMTP_PORT=587
TOKENSAVER_SMTP_USER=
TOKENSAVER_SMTP_PASSWORD=
TOKENSAVER_SMTP_FROM=tokensaver@localhost
